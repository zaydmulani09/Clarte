# Clarte IDE Environment Variables

# Gemini API Key (Injected by AI Studio)
GEMINI_API_KEY=

# App URL (Injected by AI Studio)
APP_URL=

# JWT Secret for session management (Any long random string of your choice)
JWT_SECRET=

# Google OAuth Credentials
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
